# Copy this file to .env, then fill in your remote OpenAI-compatible model API.

# Example: https://abc123.cpolar.top/v1
# Example: https://your-domain.example/v1
MODEL_API_BASE_URL=https://your-public-model-api.example/v1

# Leave empty only if your remote API intentionally has no authentication.
MODEL_API_KEY=replace-with-your-api-key

# Must match the model id exposed by your remote API.
MODEL_NAME=qwen3.5-27b@q3_k_s
